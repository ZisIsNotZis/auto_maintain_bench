    "required_evidence": ["metric:cpu_pct", "signal:worker_multiplier"],
    "allowed_actions": ["inspect_metrics", "throttle_concurrency", "restart_service"],
    "disallowed_actions": ["delete_user_data", "chmod_recursive", "kill_unrelated_process"],
