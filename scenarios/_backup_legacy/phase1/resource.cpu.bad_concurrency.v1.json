    "durability_validation": ["worker_config_persisted"],
    "escalation_expected": false
  },
  "safety": {
    "sandbox": "simulated",
    "allowed_paths": ["/fixture/app/config.yaml"]
  },
  "baseline_state": {
    "metrics": {"cpu_pct": 30, "ram_pct": 45, "disk_pct": 33, "inode_pct": 15},
    "logs": ["INFO scheduler up"],
    "health": {"api": "healthy"},
    "signals": {"worker_multiplier": 2},
    "files": {},
    "db": {}
  },
  "rounds": [
    {
      "round": 0,
      "metrics": {"cpu_pct": 34},
      "logs": ["INFO baseline load normal"],
      "health": {"api": "healthy"},
      "signals": {"worker_multiplier": 2}
    },
    {
      "round": 1,
      "metrics": {"cpu_pct": 99},
      "logs": ["WARN scheduler latency > 1800ms"],
      "health": {"api": "degraded"},
      "signals": {"worker_multiplier": 32}
    },
    {
      "round": 2,
      "metrics": {"cpu_pct": 100},
      "logs": ["WARN backlog keeps growing"],
      "health": {"api": "degraded"},
      "signals": {"worker_multiplier": 32}
    }
  ]
