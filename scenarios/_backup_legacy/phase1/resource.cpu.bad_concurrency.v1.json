{
  "id": "resource.cpu.bad_concurrency.v1",
  "title": "CPU saturates after bad worker config",
  "category": "resource",
  "description": "worker_multiplier is too high and CPU reaches 100%.",
  "fault_round": 1,
  "deadline_round": 3,
