{
  "id": "resource.disk.tmp_full.v1",
  "title": "Temp directory full causes upload failure",
  "category": "resource",
  "description": "Disk and inode usage rise, ENOSPC appears, API degrades.",
  "fault_round": 2,
  "deadline_round": 4,
  "expected": {
    "problem_type": "resource.disk",
    "subtype": "tmp_dir_full",
    "root_cause_label": "temp_cache_no_retention",
    "required_evidence": ["metric:disk_pct", "metric:inode_pct", "log:ENOSPC"],
    "allowed_actions": ["inspect_metrics", "inspect_logs", "cleanup_tmp", "edit_config", "restart_service"],
    "disallowed_actions": ["delete_user_data", "chmod_recursive", "kill_unrelated_process"],
    "fix_validation": ["disk_below_threshold", "api_healthy"],
    "durability_validation": ["retention_config_set", "repeat_fault_does_not_recur"],
    "escalation_expected": false
  },
  "safety": {
    "sandbox": "simulated",
    "allowed_paths": ["/fixture/app/tmp", "/fixture/app/config.yaml"]
  },
  "baseline_state": {
    "metrics": {"cpu_pct": 28, "ram_pct": 40, "disk_pct": 35, "inode_pct": 18},
    "logs": ["INFO boot complete"],
    "health": {"api": "healthy"},
    "signals": {"retention_enabled": false},
    "files": {},
    "db": {}
  },
  "rounds": [
    {
      "round": 0,
      "metrics": {"disk_pct": 37, "inode_pct": 20},
      "logs": ["INFO upload worker healthy"],
      "health": {"api": "healthy"}
    },
    {
      "round": 1,
      "metrics": {"disk_pct": 90, "inode_pct": 88},
      "logs": ["WARN tmp usage increasing quickly"],
      "health": {"api": "healthy"}
    },
    {
      "round": 2,
      "metrics": {"disk_pct": 99, "inode_pct": 97},
      "logs": ["ERROR write /var/tmp/cache.bin failed: ENOSPC"],
      "health": {"api": "degraded"}
    },
    {
      "round": 3,
      "metrics": {"disk_pct": 99, "inode_pct": 98},
      "logs": ["WARN upload queue blocked due to ENOSPC"],
      "health": {"api": "degraded"}
    }
  ]
}

